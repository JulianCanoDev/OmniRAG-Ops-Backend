# --- Google Generative AI ---
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Qdrant Vector Database ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
COLLECTION_NAME=omnirarg_docs

# --- Embedding ---
EMBEDDING_MODEL_ID=models/gemini-embedding-2
EMBEDDING_OUTPUT_DIMENSIONALITY=1536

# --- Server ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# --- Ingestion ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# --- PostgreSQL (RecordManager) ---
DATABASE_URL=postgresql+psycopg2://omnirg:omnirg@db:5432/omnirg
RECORD_MANAGER_NAMESPACE=omnirag/upsert_records

# --- Auth / JWT ---
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
